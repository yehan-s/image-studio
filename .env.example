# 图片接口：BYOK 模式——每个用户用自己的 sub2api key 登录并生图（扣自己额度）
SUB2API_BASE_URL=https://your-sub2api.example.com/v1
# 可选：BYOK 下可留空。仅作 prompt 优化的全局回退（见 PROMPT_OPTIMIZER_FALLBACK_GLOBAL）
SUB2API_API_KEY=
IMAGE_MODEL=gpt-image-2

# 提示词优化：复用图片接口的 Base URL / API Key / OAuth，仅单独指定文本模型
PROMPT_OPTIMIZER_MODEL=gpt-5.5

# 存储与数据库
IMAGE_STORAGE_DIR=./data/images
DATABASE_URL=file:./data/app.db

# 运行参数
IMAGE_REQUEST_TIMEOUT_MS=300000
WORKER_POLL_INTERVAL_MS=3000
COST_PER_IMAGE=0.04
# 可选：用于自动判断 HTTPS Cookie，例如 https://images.example.com
APP_BASE_URL=
# HTTP 内网部署设为 false；HTTPS/公网建议设为 true
SESSION_COOKIE_SECURE=false

# 在线更新：默认检查 laolin5564/canvas-realm-gpt-image-2-studio 的 GitHub Releases
UPDATE_REPO=laolin5564/canvas-realm-gpt-image-2-studio
UPDATE_CHECK_URL=https://api.github.com/repos/laolin5564/canvas-realm-gpt-image-2-studio/releases/latest
# Web 一键更新默认关闭；开启前请阅读 README 中的 Docker socket 风险说明
WEB_UPDATE_ENABLED=false
# Docker 内启用时必须改为宿主机 Git 项目的相同绝对路径；不要使用 /app 镜像目录
WEB_UPDATE_REPO_DIR=/app
# 可选：Web 更新脚本锁文件路径
WEB_UPDATE_LOCK_FILE=/tmp/canvas-realm-studio-web-update.lock

# 【BYOK 必填】加密每个用户存储的 sub2api key（也用于 OpenAI OAuth token）。
# 生成：openssl rand -base64 32 → 写成 base64:<值>
OPENAI_OAUTH_TOKEN_ENCRYPTION_KEY=
# 可选：站长 key 的 sha256 hex（echo -n "<key>" | shasum -a256），用于锁定管理员、防被抢
ADMIN_SUB2API_KEY_HASH=
# 可选：true 时 prompt 优化在用户 key 不可用时回退全局 SUB2API_API_KEY（站长承担文本额度），默认 false
PROMPT_OPTIMIZER_FALLBACK_GLOBAL=false

# 【SSO 阶段二】用 sub2api 账号登录、由 sub2api 现签临时 key。留空 SUB2API_SSO_SHARED_SECRET 即关闭 SSO（登录页不显示该入口）。
# 共享密钥须与 sub2api 服务端 SSO_SHARED_SECRET 完全一致（子产品后端调 /sso/token 的鉴权）
SUB2API_SSO_SHARED_SECRET=
# SSO 管理 API base（sub2api 的 /api/v1 根，与生图网关 SUB2API_BASE_URL 的 /v1 根不同）。不配则从 SUB2API_BASE_URL 的 origin 派生 ${origin}/api/v1
SUB2API_SSO_BASE_URL=
# sub2api 前端 SPA 的源（SSO 中继页 /sso 所在）。不配则取 SUB2API_BASE_URL 的 origin
SUB2API_APP_URL=
# 可选：固定 OAuth 回调地址，例如 https://your-domain.example.com/api/admin/openai-accounts/oauth/callback
OPENAI_OAUTH_REDIRECT_URI=
# 可选：默认使用 Codex CLI OAuth client_id；如 OpenAI 流程变更，可显式覆盖
OPENAI_OAUTH_CLIENT_ID=
# 预留：OAuth 图片生成当前默认走 ChatGPT Codex Responses 桥接，不直接调用 Platform images Base URL
OPENAI_OAUTH_API_BASE_URL=https://api.openai.com/v1
